            <p class="text-gray-300 text-sm md:text-base mb-16 leading-relaxed max-w-2xl mx-auto">
                {t("contact.airbnb_notice").split('All reservations')[0]}<br class="hidden md:inline">
                <a href="#rooms-section" class="text-[#c2a373] border-b border-[#c2a373] pb-0.5 hover:text-white transition-colors duration-300" set:html={t("contact.airbnb_notice").split('All reservations')[1]}></a>
            </p>
            
            <div class="bg-[#121110] p-8 md:p-12 text-left border border-gray-800 rounded-sm relative">
                <h3 class="text-xl serif text-[#c2a373] mb-6">{t("contact.form.title")}</h3>
                <form id="contactForm" class="space-y-6">
                    <div>
                        <label class="block text-xs uppercase tracking-widest text-gray-500 mb-2">{t("contact.form.name")}</label>
                        <input type="text" id="name" required class="w-full bg-transparent border-b border-gray-700 text-white focus:outline-none focus:border-[#c2a373] py-2">
                    </div>
                    <div>
                        <label class="block text-xs uppercase tracking-widest text-gray-500 mb-2">{t("contact.form.email")}</label>
                        <input type="email" id="email" required class="w-full bg-transparent border-b border-gray-700 text-white focus:outline-none focus:border-[#c2a373] py-2">
                    </div>
                    <div>
                        <label class="block text-xs uppercase tracking-widest text-gray-500 mb-2">{t("contact.form.message")}</label>
                        <textarea id="message" rows="4" required class="w-full bg-transparent border-b border-gray-700 text-white focus:outline-none focus:border-[#c2a373] py-2 resize-none"></textarea>
                    </div>
                    
                    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                        <button type="submit" id="submitBtn" class="text-xs tracking-widest uppercase text-[#c2a373] border border-[#c2a373] px-8 py-3 hover:bg-[#c2a373] hover:text-black transition-all disabled:opacity-50 disabled:cursor-not-allowed">{t("contact.form.send")}</button>
                        
                        <p class="text-[10px] text-gray-600 max-w-xs leading-tight">
                            {t("contact.form.captcha_disclosure")}
                        </p>
                    </div>
                </form>
                <div id="successMsg" class="absolute inset-0 bg-[#121110] flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-2000 z-10">
                    <p class="text-[#c2a373] serif text-xl">{t("contact.success_msg")}</p>
                </div>
            </div>
        </section>

        <!-- Footer -->
        <footer class="bg-[#080807] py-16 text-center border-t border-gray-900">
            <h2 class="text-2xl serif text-[#c2a373] mb-2">{t("footer.brand")}</h2>
            <p class="text-gray-600 text-xs tracking-[0.3em] uppercase mb-8">{t("footer.location")}</p>
            <p class="text-gray-700 text-[10px] tracking-widest" id="copyright-text"></p>
        </footer>

        <script is:inline>
            // JS scripts remain the same...
        </script>
    </div>
</Layout>