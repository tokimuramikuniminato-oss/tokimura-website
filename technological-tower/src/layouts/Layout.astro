---
import { ui } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  lang?: string;
}

const { lang = "en", title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-YWZ1R8JXHL"></script>
    <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-YWZ1R8JXHL');
    </script>

    <!-- reCAPTCHA v3 API -->
    <script src="https://www.google.com/recaptcha/api.js?render=6LeA-pAsAAAAANYCl1NTkfKlQYPuOC8lDi0rAKv9"></script>

    <!-- meta -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Lato:wght@300;400&display=swap" rel="stylesheet">
    <link rel="icon" href="/images/icon.ico" type="image/x-icon">
    <link rel="apple-touch-icon" href="/images/icon.ico" sizes="180x180">

    
    <style is:global>
        :root {
            --bg-color: #0d0c0b;
            --text-main: #e8dfd5;
            --text-accent: #c2a373;
            --text-muted: #8c857d;
        }
        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: 'Lato', sans-serif;
            font-weight: 300;
            line-height: 1.8;
        }
        h1, h2, h3, h4, .serif {
            font-family: 'Cormorant Garamond', serif;
        }
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }
        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }
        .delay-200 { transition-delay: 200ms; }
        .delay-400 { transition-delay: 400ms; }
        .hero-overlay {
            background: linear-gradient(to bottom, rgba(13,12,11,0.3) 0%, rgba(13,12,11,1) 100%);
        }
        .gold-divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--text-accent), transparent);
            opacity: 0.3;
        }
        .btn-gold {
            border: 1px solid var(--text-accent);
            color: var(--text-accent);
            transition: all 0.4s ease;
            display: inline-block;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-size: 0.85rem;
            text-decoration: none;
        }
        .btn-gold:hover {
            background-color: var(--text-accent);
            color: var(--bg-color);
        }
        /* reCAPTCHAロゴを非表示にする */
        .grecaptcha-badge {
            visibility: hidden !important;
        }
    </style>
    
  </head>
  <body class="antialiased selection:bg-[#c2a373] selection:text-[#0d0c0b]">
    <slot />
  </body>
</html>